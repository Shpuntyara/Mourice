# Copy to .env and fill in. NEVER commit .env.

# --- LLM (Ollama) ---
MOURICE_OLLAMA_HOST=http://localhost:11434
MOURICE_DEFAULT_MODEL=qwen2.5:14b
MOURICE_EMBEDDING_MODEL=bge-m3

# --- Knowledge base ---
MOURICE_OBSIDIAN_VAULT=C:/Users/sashk/Documents/Obsidian Vault
MOURICE_CHROMA_DIR=C:/Users/sashk/ChromaDB
MOURICE_CHROMA_COLLECTION=mourice_memory

# --- Runtime ---
# --- Voice (Phase 2; needs the 'voice' extra) ---
MOURICE_WHISPER_MODEL=small
MOURICE_VOICE_LANGUAGE=ru
MOURICE_PIPER_VOICE=/path/to/ru_RU-dmitri-medium.onnx

# --- Telegram (Phase 3; needs the 'telegram' extra) ---
# Get a token from @BotFather; find your numeric id via @userinfobot.
MOURICE_TELEGRAM_TOKEN=
MOURICE_TELEGRAM_OWNER_ID=0
# Also reply with synthesized audio (needs the 'voice' extra + a configured TTS engine).
MOURICE_TELEGRAM_VOICE_REPLY=false

# --- System access (file + shell tools; dangerous ops ask for confirmation) ---
MOURICE_SYSTEM_TOOLS=true

MOURICE_LOG_LEVEL=INFO
